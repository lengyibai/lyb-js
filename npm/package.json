  "description": "JavaScript utility library",
  "license": "ISC",
  "type": "module",
  "types": "./index.d.ts",
  "main": "./index.js",
  "module": "./index.js",
  "files": [
    "*.js",
    "*.d.ts",
    "Base",
    "Browser",
    "Data",
    "File",
    "Formatter",
    "Math",
    "Misc",
    "Random",
    "Time",
    "README.md"
  ],
  "exports": {
    ".": "./index.js",
    "./Base": "./Base/index.js",
    "./Base/*": "./Base/*",
    "./Browser": "./Browser/index.js",
    "./Browser/*": "./Browser/*",
    "./Data": "./Data/index.js",
    "./Data/*": "./Data/*",
    "./File": "./File/index.js",
    "./File/*": "./File/*",
    "./Formatter": "./Formatter/index.js",
    "./Formatter/*": "./Formatter/*",
    "./Math": "./Math/index.js",
    "./Math/*": "./Math/*",
    "./Misc": "./Misc/index.js",
    "./Misc/*": "./Misc/*",
    "./Random": "./Random/index.js",
    "./Random/*": "./Random/*",
    "./Time": "./Time/index.js",
    "./Time/*": "./Time/*"
  },
  "author": {
    "name": "lengyibai",
    "email": "1329670984@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lengyibai/lyb-js.git"
  },
  "keywords": [
    "lengyibai",
    "lyb",
    "lyb-js",
    "javascript"
  ],
  "dependencies": {
    "dayjs": "^1.11.13",
    "decimal.js": "^10.4.3"
  }
